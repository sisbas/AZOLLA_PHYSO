{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azolla.local/schemas/phenotyping/analyze-response/v1",
  "title": "PhenotypingAnalyzeResponseV1",
  "type": "object",
  "required": [
    "schema_version",
    "data"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "data": {
      "type": "object",
      "required": [
        "results",
        "group_comparisons"
      ],
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "file_name",
              "group_name",
              "timepoint",
              "result",
              "frame"
            ],
            "properties": {
              "file_name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "group_name": {
                "type": "string"
              },
              "timepoint": {
                "type": "string"
              },
              "replicate_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "result": {
                "type": "object",
                "required": [
                  "segmentasyon",
                  "renk_indeksleri",
                  "stres_analizi",
                  "yogunluk_dagilimi",
                  "doku_analizi",
                  "biyokutle_tahmini",
                  "buyume_parametreleri",
                  "images",
                  "timestamp",
                  "qc"
                ],
                "properties": {
                  "segmentasyon": {
                    "type": "object"
                  },
                  "renk_indeksleri": {
                    "type": "object",
                    "description": "Renk/indeks dönüşümleri içindir (örn. ExG, TREx, ExR, HSV ve LAB tabanlı renk/indeks değerleri); GLCM doku metrikleri burada döndürülmez."
                  },
                  "stres_analizi": {
                    "type": "object"
                  },
                  "yogunluk_dagilimi": {
                    "type": "object"
                  },
                  "doku_analizi": {
                    "type": "object",
                    "properties": {
                      "contrast": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "homogeneity": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "energy": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "correlation": {
                        "type": [
                          "number",
                          "null"
                        ]
                      }
                    },
                    "additionalProperties": true,
                    "description": "GLCM doku analizi metrikleri içindir (contrast, homogeneity, energy, correlation)."
                  },
                  "biyokutle_tahmini": {
                    "type": "object"
                  },
                  "buyume_parametreleri": {
                    "type": "object"
                  },
                  "date_comparison": {
                    "type": "object",
                    "required": [
                      "days_diff",
                      "start_date",
                      "end_date"
                    ],
                    "properties": {
                      "days_diff": {
                        "type": "integer"
                      },
                      "start_date": {
                        "type": "string",
                        "format": "date"
                      },
                      "end_date": {
                        "type": "string",
                        "format": "date"
                      }
                    },
                    "additionalProperties": true
                  },
                  "images": {
                    "type": "object",
                    "required": [
                      "preprocessed_rgb_png",
                      "binary_mask_png",
                      "isolated_rgb_png",
                      "overlay_png"
                    ],
                    "properties": {
                      "preprocessed_rgb_png": {
                        "type": "string"
                      },
                      "binary_mask_png": {
                        "type": "string"
                      },
                      "isolated_rgb_png": {
                        "type": "string"
                      },
                      "overlay_png": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  },
                  "timestamp": {
                    "type": "string"
                  },
                  "qc": {
                    "type": "object",
                    "required": [
                      "coverage_pct",
                      "quality_score",
                      "warnings",
                      "leakage_pct",
                      "plant_fill_pct"
                    ],
                    "properties": {
                      "coverage_pct": {
                        "type": "number"
                      },
                      "quality_score": {
                        "type": "number"
                      },
                      "warnings": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "leakage_pct": {
                        "type": "number"
                      },
                      "plant_fill_pct": {
                        "type": "number"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": true
              },
              "frame": {
                "type": "object",
                "description": "Timeline/consumer-ready birleşik metrik katmanı. result içindeki ham alanlardan map edilir ve geçersiz değerlerde explicit null döner.",
                "required": [
                  "phenotyping",
                  "metrics"
                ],
                "properties": {
                  "phenotyping": {
                    "type": "object",
                    "required": [
                      "chlorophyll_index",
                      "fresh_biomass_g_m2"
                    ],
                    "properties": {
                      "chlorophyll_index": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "result.renk_indeksleri.chlorophyll_index alanının map edilmiş hali; null/NaN ise null."
                      },
                      "fresh_biomass_g_m2": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "result.biyokutle_tahmini.fresh_biomass_g_m2 alanının map edilmiş hali; null/NaN ise null."
                      }
                    },
                    "additionalProperties": true
                  },
                  "metrics": {
                    "type": "object",
                    "required": [
                      "rg_ratio"
                    ],
                    "properties": {
                      "rg_ratio": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "Öncelik: result.metrics.rg_ratio veya result.renk_indeksleri.rg_ratio. Yoksa result.metrics.mean_r/mean_g ile backend türetir. Geçersiz/null/NaN durumlarında null."
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        },
        "group_comparisons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "group_name",
              "before_summary",
              "after_summary",
              "change_summary",
              "warnings"
            ],
            "properties": {
              "group_name": {
                "type": "string"
              },
              "before_summary": {
                "type": "object",
                "required": [
                  "count",
                  "metrics"
                ],
                "properties": {
                  "count": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "metrics": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": [
                        "mean",
                        "median",
                        "count"
                      ],
                      "properties": {
                        "mean": {
                          "type": "number"
                        },
                        "median": {
                          "type": "number"
                        },
                        "count": {
                          "type": "integer",
                          "minimum": 0
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              },
              "after_summary": {
                "type": "object",
                "required": [
                  "count",
                  "metrics"
                ],
                "properties": {
                  "count": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "metrics": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": [
                        "mean",
                        "median",
                        "count"
                      ],
                      "properties": {
                        "mean": {
                          "type": "number"
                        },
                        "median": {
                          "type": "number"
                        },
                        "count": {
                          "type": "integer",
                          "minimum": 0
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              },
              "change_summary": {
                "type": "object",
                "required": [
                  "metrics"
                ],
                "properties": {
                  "metrics": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": [
                        "delta",
                        "pct_change"
                      ],
                      "properties": {
                        "delta": {
                          "type": "number"
                        },
                        "pct_change": {
                          "type": [
                            "number",
                            "null"
                          ]
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
